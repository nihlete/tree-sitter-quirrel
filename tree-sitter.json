{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "quirrel",
      "camelcase": "Quirrel",
      "title": "Quirrel",
      "scope": "source.quirrel",
      "file-types": [
        ".nut"
      ],
      "injection-regex": "^quirrel$",
      "class-name": "TreeSitterQuirrel"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parser for Quirrel language https://quirrel.io/",
    "authors": [
      {
        "name": "Andrei Voronin",
        "email": "nihlete@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/nihlete/tree-sitter-quirrel"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}